{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "mamasparshschool.in"
        }
      ],
      "destination": "https://www.mamasparshschool.in/$1",
      "permanent": true
    }
  ]
}
